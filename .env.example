# ═══════════════════════════════════════════════════════════════
#  Social Publisher — Environment Variables
#  העתק קובץ זה ל-.env (או הגדר ב-Render Dashboard)
# ═══════════════════════════════════════════════════════════════

# ─── Google Service Account ──────────────────────────────────
# כל ה-JSON של ה-Service Account כמחרוזת אחת
# ב-Render: הדבק את כל תוכן ה-JSON בשדה אחד
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ─── Google Sheets ───────────────────────────────────────────
# ה-ID של ה-Spreadsheet (מופיע ב-URL)
# https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# שם הגיליון (Tab) — ברירת מחדל: Sheet1
SHEET_NAME=Sheet1

# ─── Cloudinary ──────────────────────────────────────────────
# אפשרות 1 (מועדפת): כתובת URL אחת — העתיקו מה-Dashboard של Cloudinary
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# אפשרות 2: שלושה משתנים נפרדים
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret

# מספר ימים לשמור נכסים ב-Cloudinary אחרי פרסום (ברירת מחדל: 10)
# CLOUDINARY_RETENTION_DAYS=10

# ─── Meta / Instagram ───────────────────────────────────────
# גרסת ה-API (ברירת מחדל: v21.0)
META_API_VERSION=v21.0

# IG User ID — מזהה חשבון ה-Instagram Business
# ניתן למצוא דרך: GET /me/accounts → ig_business_account
IG_USER_ID=17841400000000000

# טוקן עם הרשאות: instagram_basic, instagram_content_publish, pages_show_list
IG_ACCESS_TOKEN=EAA...

# ─── Meta / Facebook Page ───────────────────────────────────
# Page ID — מזהה העמוד העסקי
FB_PAGE_ID=100000000000000

# Page Access Token — טוקן ארוך טווח של העמוד
# עם הרשאות: pages_manage_posts, pages_read_engagement
FB_PAGE_ACCESS_TOKEN=EAA...

# ─── Google Business Profile — OAuth 2.0 ──────────────────
# חשבון GBP (מופיע ב-API כ-accounts/XXXXXXXXX)
GBP_ACCOUNT_ID=accounts/123456789

# OAuth 2.0 credentials — ניתן ליצור ב-Google Cloud Console
# APIs & Services → Credentials → OAuth 2.0 Client IDs
GBP_OAUTH_CLIENT_ID=your_client_id.apps.googleusercontent.com
GBP_OAUTH_CLIENT_SECRET=your_client_secret

# Refresh token — מתקבל לאחר הרשאת OAuth עם scope: business.manage
# ניתן ליצור דרך OAuth Playground או תהליך הרשאה ידני
GBP_REFRESH_TOKEN=your_refresh_token

# Feature flag — set to true to enable GBP channel (default: false)
# Use for phased rollout: deploy code first, then enable when ready
GBP_ENABLED=false

# הערה: google_location_id נשמר ברמת שורה בטבלה, לא כ-env var גלובלי
# כך שאפשר לפרסם לכמה מיקומים שונים מאותו חשבון

# ─── Google Drive (Web Panel) ──────────────────────────────
# מזהה תיקיית Drive שממנה הלקוחה בוחרת קבצים
# (תיקייה שה-Service Account מורשה אליה)
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# ─── Web Panel Authentication ────────────────────────────
# סיסמה לפאנל הניהול (חובה בפרודקשן!)
# WEB_PANEL_SECRET=your_panel_password_here

# סיסמה למפתח — מאפשרת צפייה ב-file IDs מלאים בפאנל (אופציונלי)
# WEB_PANEL_DEV_SECRET=your_dev_password_here

# ─── LinkedIn — OAuth 2.0 ─────────────────────────────────
# OAuth 2.0 credentials — ניתן ליצור ב-LinkedIn Developer Portal
# https://developer.linkedin.com/ → My Apps → Auth tab
LI_OAUTH_CLIENT_ID=your_client_id
LI_OAUTH_CLIENT_SECRET=WPL_AP1.xxxxxxxx.xxxxxx==

# Refresh token — מתקבל לאחר הרשאת OAuth עם scope: w_member_social
# ניתן ליצור דרך scripts/linkedin_oauth.py
LI_REFRESH_TOKEN=your_refresh_token

# ─── Publish Retry ────────────────────────────────────────
# מספר ניסיונות חוזרים לפרסום (ברירת מחדל: 3)
# PUBLISH_MAX_RETRIES=3

# זמן המתנה בין ניסיונות בשניות (ברירת מחדל: 5)
# PUBLISH_RETRY_DELAY=5

# ─── Project Identity (אופציונלי) ──────────────────────────
# שם הלקוח/פרויקט — מופיע בהתראות טלגרם
# CLIENT_NAME=שם הלקוחה
# קישור לריפו — מופיע בהתראות טלגרם (על תפוגת Meta API)
# REPO_URL=https://github.com/amirbiron/Social-publisher
# כתובת האפליקציה הרצה — יוצרת "deep link" בהתראות טלגרם לפוסט הרלוונטי
# חייב להיות מוגדר גם ב-cron וגם ב-web כדי שכל ההתראות יכללו קישור
# APP_BASE_URL=https://social-publisher-panel.onrender.com

# ─── Telegram Notifications (אופציונלי) ──────────────────
# התראות למפתח כשפוסט נכשל או מצליח חלקית.
# צרו בוט דרך @BotFather בטלגרם וקבלו את ה-Token.
# את ה-Chat ID אפשר לקבל דרך @userinfobot או מ-API: getUpdates
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_CHAT_ID=123456789,987654321
